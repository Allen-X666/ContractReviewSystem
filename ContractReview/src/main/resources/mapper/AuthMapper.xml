<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.contractreview.mapper.AuthMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.example.contractreview.model.entity.User">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="nick_name" property="nickName"/>
        <result column="email" property="email"/>
        <result column="phone" property="phone"/>
        <result column="avatar" property="avatar"/>
        <result column="role" property="role" typeHandler="com.example.contractreview.enums.UserRoleTypeHandler"/>
        <result column="status" property="status" typeHandler="com.example.contractreview.enums.UserStatusTypeHandler"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <!-- 根据ID查询用户 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT *
        FROM sys_user
        WHERE id = #{id}
    </select>

    <!-- 根据用户名查询用户 -->
    <select id="selectByUsername" resultMap="BaseResultMap">
        SELECT *
        FROM sys_user
        WHERE username = #{username}
    </select>

    <!-- 根据邮箱查询用户 -->
    <select id="selectByEmail" resultMap="BaseResultMap">
        SELECT *
        FROM sys_user
        WHERE email = #{email}
    </select>

    <!-- 根据手机号查询用户 -->
    <select id="selectByPhone" resultMap="BaseResultMap">
        SELECT *
        FROM sys_user
        WHERE phone = #{phone}
    </select>

    <!-- 判断用户名是否存在 -->
    <select id="existsByUsername" resultType="boolean">
        SELECT COUNT(*) > 0 FROM sys_user WHERE username = #{username}
    </select>

    <!-- 判断邮箱是否存在 -->
    <select id="existsByEmail" resultType="boolean">
        SELECT COUNT(*) > 0 FROM sys_user WHERE email = #{email}
    </select>

    <!-- 判断手机号是否存在 -->
    <select id="existsByPhone" resultType="boolean">
        SELECT COUNT(*) > 0 FROM sys_user WHERE phone = #{phone}
    </select>

    <!-- 插入用户 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_user (
            username,
            password,
            nick_name,
            email,
            phone,
            avatar,
            role,
            status,
            created_at,
            updated_at
        ) VALUES (
            #{username},
            #{password},
            #{nickName},
            #{email},
            #{phone},
            #{avatar},
            #{role, typeHandler=com.example.contractreview.enums.UserRoleTypeHandler},
            #{status, typeHandler=com.example.contractreview.enums.UserStatusTypeHandler},
            #{createdAt},
            #{updatedAt}
        )
    </insert>
    <insert id="insertSystemDocument"></insert>

    <!-- 更新用户 -->
    <update id="update">
        UPDATE sys_user
        <set>
            <if test="password != null">password = #{password},</if>
            <if test="nickName != null">nick_name = #{nickName},</if>
            <if test="email != null">email = #{email},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="role != null">role = #{role, typeHandler=com.example.contractreview.enums.UserRoleTypeHandler},</if>
            <if test="status != null">status = #{status, typeHandler=com.example.contractreview.enums.UserStatusTypeHandler},</if>
            updated_at = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <!-- 根据ID删除用户 -->
    <delete id="deleteById">
        DELETE FROM sys_user WHERE id = #{id}
    </delete>

    <!-- 查询所有用户 -->
    <select id="selectAllUsers" resultMap="BaseResultMap">
        SELECT *
        FROM sys_user
        ORDER BY created_at DESC
    </select>

    <!-- 管理员更新用户信息 -->
    <update id="updateByAdmin">
        UPDATE sys_user
        <set>
            <if test="adminUpdateUserDTO.username != null and adminUpdateUserDTO.username != ''">username = #{adminUpdateUserDTO.username},</if>
            <if test="adminUpdateUserDTO.nickName != null and adminUpdateUserDTO.nickName != ''">nick_name = #{adminUpdateUserDTO.nickName},</if>
            <if test="adminUpdateUserDTO.email != null and adminUpdateUserDTO.email != ''">email = #{adminUpdateUserDTO.email},</if>
            <if test="adminUpdateUserDTO.phone != null and adminUpdateUserDTO.phone != ''">phone = #{adminUpdateUserDTO.phone},</if>
            <if test="adminUpdateUserDTO.role != null">role = #{adminUpdateUserDTO.role},</if>
            updated_at = NOW()
        </set>
        WHERE id = #{userId}
    </update>

    <!-- 更新用户状态 -->
    <update id="updateStatus">
        UPDATE sys_user
        SET status = #{status, typeHandler=com.example.contractreview.enums.UserStatusTypeHandler},
            updated_at = NOW()
        WHERE id = #{userId}
    </update>
    <update id="updatePassword">
        UPDATE sys_user
        SET password = #{password},
            updated_at = NOW()
        WHERE email = #{email}
    </update>

    <!-- 判断用户名是否存在（排除指定用户） -->
    <select id="existsByUsernameExcludeId" resultType="boolean">
        SELECT COUNT(*) > 0 FROM sys_user
        WHERE username = #{username} AND id != #{excludeId}
    </select>

    <!-- 判断邮箱是否存在（排除指定用户） -->
    <select id="existsByEmailExcludeId" resultType="boolean">
        SELECT COUNT(*) > 0 FROM sys_user
        WHERE email = #{email} AND id != #{excludeId}
    </select>

    <!-- 判断手机号是否存在（排除指定用户） -->
    <select id="existsByPhoneExcludeId" resultType="boolean">
        SELECT COUNT(*) > 0 FROM sys_user
        WHERE phone = #{phone} AND id != #{excludeId}
    </select>

</mapper>
