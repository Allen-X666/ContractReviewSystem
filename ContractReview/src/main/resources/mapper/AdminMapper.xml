<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.contractreview.mapper.AdminMapper">

    <!-- SystemDocument 结果映射 -->
    <resultMap id="SystemDocumentResultMap" type="com.example.contractreview.model.entity.SystemDocument">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="category" column="category"/>
        <result property="tags" column="tags" typeHandler="com.example.contractreview.config.JsonListTypeHandler"/>
        <result property="description" column="description"/>
        <result property="filePath" column="file_path"/>
        <result property="fileSize" column="file_size"/>
        <result property="status" column="status"/>
        <result property="createAt" column="create_at"/>
    </resultMap>

    <!-- SelectSystemDocumentListVO 结果映射 -->
    <resultMap id="SelectSystemDocumentListVOResultMap" type="com.example.contractreview.model.vo.SelectSystemDocumentListVO">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="category" column="category"/>
        <result property="tags" column="tags" typeHandler="com.example.contractreview.config.JsonListTypeHandler"/>
        <result property="createAt" column="create_at"/>
    </resultMap>

    <delete id="deleteLawDocumentById">
        DELETE FROM system_document
        WHERE id = #{id}
    </delete>

    <!-- LawRegulation 结果映射 -->
    <resultMap id="LawRegulationResultMap" type="com.example.contractreview.model.entity.LawRegulation">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="category" column="category" typeHandler="com.example.contractreview.config.LawCategoryTypeHandler"/>
        <result property="issuer" column="issuer"/>
        <result property="publishDate" column="publish_date"/>
        <result property="effectiveDate" column="effective_date"/>
        <result property="status" column="status" typeHandler="com.example.contractreview.config.MyBatisEnumTypeHandler"/>
        <result property="description" column="description"/>
        <result property="isNew" column="is_new"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <!-- 根据名称列表批量查询 -->
    <select id="selectByNames" resultMap="LawRegulationResultMap">
        SELECT
            id, name, category, issuer, publish_date, effective_date,
            status, description, is_new, created_at
        FROM law_regulation
        WHERE name IN
        <foreach collection="names" item="name" open="(" separator="," close=")">
            #{name}
        </foreach>
    </select>

    <!-- 批量插入法规 -->
    <insert id="insertLawRegulation" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO law_regulation (
            name, category, issuer, publish_date, effective_date,
            status, description, is_new, created_at
        ) VALUES
        <foreach collection="lawRegulation" item="item" separator=",">
            (
                #{item.name},
                #{item.category, typeHandler=com.example.contractreview.config.MyBatisEnumTypeHandler},
                #{item.issuer},
                #{item.publishDate},
                #{item.effectiveDate},
                #{item.status, typeHandler=com.example.contractreview.config.MyBatisEnumTypeHandler},
                #{item.description},
                #{item.isNew},
                #{item.createdAt}
            )
        </foreach>
    </insert>

    <!-- 批量插入法条 -->
    <insert id="insertLawArticles" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO law_article (
            law_id, article_no, title, content, interpretation, created_at
        ) VALUES
        <foreach collection="lawArticles" item="item" separator=",">
            (
                #{item.lawId},
                #{item.articleNo},
                #{item.title},
                #{item.content},
                #{item.interpretation},
                #{item.createdAt}
            )
        </foreach>
    </insert>
    <!-- 插入系统文档 -->
    <insert id="insertSystemDocument" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO system_document (
            name, category, tags, description, file_path, file_size, status, create_at
        ) VALUES (
            #{name},
            #{category},
            #{tags, typeHandler=com.example.contractreview.config.JsonListTypeHandler},
            #{description},
            #{filePath},
            #{fileSize},
            #{status},
            now()
        )
    </insert>

    <!-- 查询系统文档列表 -->
    <select id="selectSystemDocumentList" resultMap="SelectSystemDocumentListVOResultMap">
        SELECT
            id, name, category, tags, create_at
        FROM system_document
        WHERE status = 1 AND id > 0
        ORDER BY create_at DESC
    </select>
    <select id="selectLawDocumentById" resultMap="SystemDocumentResultMap">
        SELECT
            id, name, category, tags, description, file_path, file_size, status, create_at
        FROM system_document
        WHERE id = #{id}
          AND id > 0
          AND status = 1
    </select>

</mapper>
